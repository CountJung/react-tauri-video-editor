{
  // в”Җв”Җ macOS м „мҡ© н„°лҜёл„җ нҷҳкІҪ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // - Homebrew, CargoлҘј PATHм—җ м¶”к°Җ (VS Code GUI кё°лҸҷ мӢң login shell лҜёлЎңл“ң лҢҖмқ‘)
  // - CARGO_TARGET_DIR: мҷёмһҘ н•ҳл“ң ._* л©”нғҖнҢҢмқј нҢЁлӢү л°©м§Җ (лӮҙл¶Җ л“ңлқјмқҙлёҢлЎң лҰ¬лӢӨмқҙл үнҠё)
  "terminal.integrated.env.osx": {
    "PATH": "/opt/homebrew/bin:/opt/homebrew/sbin:${env:HOME}/.cargo/bin:${env:PATH}",
    "CARGO_TARGET_DIR": "${env:HOME}/.cache/react-tauri-video-editor-target"
  },

  // в”Җв”Җ Windows м „мҡ© н„°лҜёл„җ нҷҳкІҪ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // - CARGO_TARGET_DIR: мҷёмһҘ л“ңлқјмқҙлёҢ мӮ¬мҡ© мӢң л№Ңл“ң мҶҚлҸ„ н–ҘмғҒ (м„ нғқ)
  "terminal.integrated.env.windows": {
    "CARGO_TARGET_DIR": "${env:USERPROFILE}\\.cache\\react-tauri-video-editor-target"
  },

  // в”Җв”Җ rust-analyzer: Cargo target кІҪлЎң к°•м ң в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // cargo.targetDir=true лҠ” мӣҢнҒ¬мҠӨнҺҳмқҙмҠӨмқҳ target/rust-analyzer н•ҳмң„м—җ мғқм„ұлҗҳлҜҖлЎң
  // exFAT нҷҳкІҪм—җм„ңлҠ” ._*.toml л©”нғҖнҢҢмқјмқҙ лӢӨмӢң мғқкёё мҲҳ мһҲмҠөлӢҲлӢӨ.
  // server/cargo/check лӘЁл“  кІҪлЎңм—җ CARGO_TARGET_DIRлҘј мЈјмһ…н•ҙ лӮҙл¶Җ л“ңлқјмқҙлёҢ мәҗмӢңлҘј к°•м ңн•©лӢҲлӢӨ.
  // rust-analyzer extraEnvлҠ” ${env:HOME} м№ҳнҷҳмқ„ кё°лҢҖн•ҳм§Җ л§җкі  мӢӨм ң м ҲлҢҖ кІҪлЎңлҘј мӮ¬мҡ©н•©лӢҲлӢӨ.
  "rust-analyzer.server.extraEnv": {
    "CARGO_TARGET_DIR": "/Users/jsjmac/.cache/react-tauri-video-editor-target/rust-analyzer"
  },
  "rust-analyzer.cargo.extraEnv": {
    "CARGO_TARGET_DIR": "/Users/jsjmac/.cache/react-tauri-video-editor-target/rust-analyzer"
  },
  "rust-analyzer.check.extraEnv": {
    "CARGO_TARGET_DIR": "/Users/jsjmac/.cache/react-tauri-video-editor-target/rust-analyzer"
  },

  // в”Җв”Җ мҷёмһҘ л“ңлқјмқҙлёҢ ._* нҢҢмқј нғҗмғүкё°м—җм„ң мҲЁкё°кё° (macOS) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "files.exclude": {
    "**/.DS_Store": true,
    "**/._*": true,
    "**/.Spotlight-V100": true,
    "**/.Trashes": true,
    "**/.fseventsd": true
  },
  "search.exclude": {
    "**/._*": true,
    "src-tauri/target": true,
    "**/node_modules": true
  }
}
